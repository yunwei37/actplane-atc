        <mxCell id="SbqmE6-mlqRPoa65LsV4-6" value="rotate64 &lt;br&gt;{dst=r7, src=r5, imm=16}" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
