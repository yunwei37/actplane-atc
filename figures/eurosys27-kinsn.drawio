        <mxCell id="SbqmE6-mlqRPoa65LsV4-3" value="&lt;div&gt;r_tmp = r_x&lt;/div&gt;&lt;div&gt;r_tmp &amp;gt;&amp;gt;= 48&lt;/div&gt;&lt;div&gt;r_dst = r_x&lt;/div&gt;&lt;div&gt;r_dst &amp;lt;&amp;lt;= 16&lt;/div&gt;&lt;div&gt;r_dst |= r_tmp&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
